{
  "name": "pex",
  "displayName": "PEX Language",
  "description": "Syntax highlighting for PEX language",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [{
      "id": "pex",
      "aliases": ["PEX", "pex"],
      "extensions": [".pi"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "pex",
      "scopeName": "source.pex",
      "path": "./syntaxes/pex.tmLanguage.json"
    }],
    "snippets": [{
      "language": "pex",
      "path": "./snippets/pex.json"
    }]
  }
}
